---
import MainLayout from "@/layouts/main.astro";
import MainMenu from "@/components/MainMenu.svelte";
import GlobalLanguageSelector from "@/components/GlobalLanguageSelector.svelte";
import ErrorBoundary from "@/components/ErrorBoundary.svelte";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Pre-compute all translations needed by MainMenu
const translations = {
  "main.title": t("main.title"),
  "main.subtitle": t("main.subtitle"),
  "main.description": t("main.description"),
  "main.solar": t("main.solar"),
  "main.explore": t("main.explore"),
  "main.galaxy": t("main.galaxy"),
  "main.settings": t("main.settings"),
  "constellation.title": t("constellation.title"),
  "aria.startGame": t("aria.startGame"),
  "aria.systems": t("aria.systems"),
  "aria.galaxy": t("aria.galaxy"),
  "aria.constellation": t("aria.constellation"),
  "aria.settings": t("aria.settings"),
  "instructions.mouse": t("instructions.mouse"),
  "instructions.scroll": t("instructions.scroll"),
  "instructions.click": t("instructions.click"),
  "instructions.keyboard": t("instructions.keyboard"),
  "instructions.enter": t("instructions.enter"),
  "systems.title": t("systems.title"),
  "systems.system": t("systems.system"),
  "action.cancel": t("action.cancel"),
  "action.close": t("action.close"),
  "aria.close": t("aria.close"),
  "sr.mainMenuLoaded": t("sr.mainMenuLoaded"),
  // SettingsModal keys — without these the modal falls back to raw key strings
  "settings.title": t("settings.title"),
  "settings.configuration": t("settings.configuration"),
  "settings.visual": t("settings.visual"),
  "settings.enableAnimations": t("settings.enableAnimations"),
  "settings.enableAnimationsDesc": t("settings.enableAnimationsDesc"),
  "settings.graphicsQuality": t("settings.graphicsQuality"),
  "settings.graphicsQualityDesc": t("settings.graphicsQualityDesc"),
  "settings.qualityLow": t("settings.qualityLow"),
  "settings.qualityMedium": t("settings.qualityMedium"),
  "settings.qualityHigh": t("settings.qualityHigh"),
  "settings.showControlHints": t("settings.showControlHints"),
  "settings.showControlHintsDesc": t("settings.showControlHintsDesc"),
  "settings.audio": t("settings.audio"),
  "settings.enableAudio": t("settings.enableAudio"),
  "settings.enableAudioDesc": t("settings.enableAudioDesc"),
  "settings.control": t("settings.control"),
  "settings.mouseSensitivity": t("settings.mouseSensitivity"),
  "settings.sensitivitySlow": t("settings.sensitivitySlow"),
  "settings.sensitivityFast": t("settings.sensitivityFast"),
  "settings.accessibility": t("settings.accessibility"),
  "settings.highContrast": t("settings.highContrast"),
  "settings.highContrastDesc": t("settings.highContrastDesc"),
  "settings.reducedMotion": t("settings.reducedMotion"),
  "settings.reducedMotionDesc": t("settings.reducedMotionDesc"),
  "settings.keyboardNavigation": t("settings.keyboardNavigation"),
  "settings.keyboardNavigationDesc": t("settings.keyboardNavigationDesc"),
  "settings.announceSceneChanges": t("settings.announceSceneChanges"),
  "settings.announceSceneChangesDesc": t("settings.announceSceneChangesDesc"),
  "settings.screenReaderMode": t("settings.screenReaderMode"),
  "settings.screenReaderModeDesc": t("settings.screenReaderModeDesc"),
  "settings.resetDefaults": t("settings.resetDefaults"),
  "settings.save": t("settings.save"),
};

const content = {
  title: t("page.title"),
  description: t("page.description"),
};
---

<MainLayout {content} lang={lang}>
  <!-- Global Language Selector -->
  <GlobalLanguageSelector client:only="svelte" />

  <ErrorBoundary client:idle>
    <MainMenu lang={lang} translations={translations} client:idle />
  </ErrorBoundary>
</MainLayout>
